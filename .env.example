# PostgreSQL (Neon, Vercel Postgres, local Docker, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Vercel Blob — Dashboard → Storage → Blob → Read/Write token
BLOB_READ_WRITE_TOKEN=""

# Admin session (модерация /e/[slug]/admin), min 16 chars in production
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# Панель /studio: bcrypt-хеш пароля (npm run studio:hash -- ваш_пароль)
# ВАЖНО (Next.js): символ $ в значениях .env подставляется как переменная.
# Перед КАЖДЫМ $ в хеше поставьте обратный слэш:
# STUDIO_PASSWORD_HASH="\$2b\$10\$......................................"
# В dev при пустом значении пароль входа: studio-dev
STUDIO_PASSWORD_HASH=
STUDIO_SESSION_SECRET="another-long-random-string-min-16-chars"

# Публичный URL сайта: ссылки и QR в Studio (на Vercel обычно https://<проект>.vercel.app)
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Optional: Upstash Redis for distributed rate limits on Vercel
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Optional: Cloudflare Turnstile on guest upload (set BOTH for server verify)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# Seed script default admin password for demo event
# SEED_ADMIN_PASSWORD="admin123"
